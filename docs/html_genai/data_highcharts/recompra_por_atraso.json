{
  "chart": {
    "type": "column"
  },
  "title": {
    "text": "Taxa de recompra por faixa de atraso"
  },
  "xAxis": {
    "categories": ["Sem atraso", "1-2 dias", "3-5 dias", "6+ dias"],
    "title": {
      "text": "Faixa de atraso"
    }
  },
  "yAxis": {
    "min": 0,
    "max": 100,
    "title": {
      "text": "% de pedidos com recompra em 30 dias"
    },
    "labels": {
      "format": "{value}%"
    }
  },
  "tooltip": {
    "pointFormat": "Pedidos com recompra: <b>{point.com_recompra}</b><br>Total de pedidos: <b>{point.total}</b><br>% com recompra: <b>{point.y:.1f}%</b>"
  },
  "plotOptions": {
    "column": {
      "dataLabels": {
        "enabled": true,
        "format": "{point.y:.1f}%"
      }
    }
  },
